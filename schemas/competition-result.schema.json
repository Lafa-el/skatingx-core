{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.skatingx.dev/competition-result.schema.json",
  "title": "SkatingX Competition Result",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "competitionId",
    "athleteId",
    "ownerUid",
    "schemaVersion",
    "eventName",
    "eventDate",
    "competitionType",
    "createdAt",
    "updatedAt",
    "sourceApp"
  ],
  "properties": {
    "competitionId": { "type": "string", "minLength": 1 },
    "athleteId": { "type": "string", "minLength": 1 },
    "ownerUid": { "type": "string", "minLength": 1 },
    "schemaVersion": { "type": "string", "pattern": "^1\\.0\\.0$" },
    "eventName": { "type": "string", "minLength": 1, "maxLength": 200 },
    "eventDate": { "$ref": "#/$defs/dateTime" },
    "timezone": { "type": "string", "maxLength": 80 },
    "competitionType": {
      "type": "string",
      "enum": ["competition", "test", "race", "game", "showcase", "assessment", "other"]
    },
    "discipline": {
      "type": "string",
      "enum": ["figure", "hockey", "speed", "synchro", "recreational", "offIce", "other"]
    },
    "level": { "type": "string", "maxLength": 120 },
    "location": { "type": "string", "maxLength": 200 },
    "program": { "type": "string", "maxLength": 160 },
    "placement": { "type": "integer", "minimum": 1 },
    "fieldSize": { "type": "integer", "minimum": 1 },
    "score": { "type": "number" },
    "scoreBreakdown": {
      "type": "object",
      "additionalProperties": {
        "type": ["number", "integer", "string", "boolean", "null"]
      }
    },
    "outcome": { "type": "string", "maxLength": 200 },
    "notes": { "type": "string", "maxLength": 4000 },
    "relatedTrainingRecordIds": {
      "type": "array",
      "items": { "type": "string" },
      "uniqueItems": true
    },
    "relatedAnalysisSessionIds": {
      "type": "array",
      "items": { "type": "string" },
      "uniqueItems": true
    },
    "visibility": { "$ref": "#/$defs/visibility" },
    "status": { "enum": ["scheduled", "completed", "cancelled", "archived"] },
    "externalRefs": { "$ref": "#/$defs/externalRefs" },
    "extensions": { "$ref": "#/$defs/extensions" },
    "createdAt": { "$ref": "#/$defs/dateTime" },
    "updatedAt": { "$ref": "#/$defs/dateTime" },
    "createdByUid": { "type": "string" },
    "updatedByUid": { "type": "string" },
    "archivedAt": { "$ref": "#/$defs/dateTime" },
    "sourceApp": { "$ref": "#/$defs/sourceApp" }
  },
  "$defs": {
    "dateTime": { "type": "string", "format": "date-time" },
    "visibility": { "type": "string", "enum": ["private", "shared", "coachOnly", "team"] },
    "sourceApp": {
      "type": "string",
      "enum": ["skatingxCore", "blazeTraining", "blazeJournal", "blazeLab", "blazeAnalysis", "skatingxPlatform", "migration"]
    },
    "externalRefs": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": { "type": ["string", "number", "boolean", "null"] }
      }
    },
    "extensions": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": true
      }
    }
  }
}
