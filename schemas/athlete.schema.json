{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.skatingx.dev/athlete.schema.json",
  "title": "SkatingX Athlete",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "athleteId",
    "ownerUid",
    "schemaVersion",
    "displayName",
    "status",
    "createdAt",
    "updatedAt",
    "sourceApp"
  ],
  "properties": {
    "athleteId": { "type": "string", "minLength": 1 },
    "ownerUid": { "type": "string", "minLength": 1 },
    "schemaVersion": { "type": "string", "pattern": "^1\\.0\\.0$" },
    "displayName": { "type": "string", "minLength": 1, "maxLength": 120 },
    "preferredName": { "type": "string", "maxLength": 80 },
    "birthYear": { "type": "integer", "minimum": 1900, "maximum": 2100 },
    "ageGroup": { "type": "string", "maxLength": 40 },
    "primaryDiscipline": { "$ref": "#/$defs/discipline" },
    "disciplines": {
      "type": "array",
      "items": { "$ref": "#/$defs/discipline" },
      "uniqueItems": true
    },
    "level": { "type": "string", "maxLength": 80 },
    "homeClub": { "type": "string", "maxLength": 160 },
    "coaches": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name"],
        "properties": {
          "uid": { "type": "string" },
          "name": { "type": "string", "minLength": 1, "maxLength": 120 },
          "role": { "type": "string", "maxLength": 80 },
          "email": { "type": "string", "format": "email" }
        }
      }
    },
    "goals": {
      "type": "array",
      "items": { "type": "string", "maxLength": 240 },
      "maxItems": 20
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "lastTrainingAt": { "$ref": "#/$defs/dateTime" },
        "lastJournalAt": { "$ref": "#/$defs/dateTime" },
        "lastAnalysisAt": { "$ref": "#/$defs/dateTime" },
        "trainingRecordCount": { "type": "integer", "minimum": 0 },
        "journalEntryCount": { "type": "integer", "minimum": 0 },
        "analysisSessionCount": { "type": "integer", "minimum": 0 }
      }
    },
    "access": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ownerUid"],
      "properties": {
        "ownerUid": { "type": "string", "minLength": 1 },
        "members": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["uid", "role", "permissions", "status"],
            "properties": {
              "uid": { "type": "string", "minLength": 1 },
              "role": {
                "type": "string",
                "enum": ["athleteOwner", "athlete", "parent", "coach", "clubAdmin", "platformAdmin"]
              },
              "permissions": {
                "type": "array",
                "items": { "enum": ["read", "write", "comment", "manageAccess", "archive"] },
                "uniqueItems": true
              },
              "status": { "enum": ["active", "invited", "removed"] }
            }
          },
          "maxItems": 50
        }
      }
    },
    "status": { "enum": ["active", "inactive", "archived"] },
    "visibility": { "$ref": "#/$defs/visibility" },
    "externalRefs": { "$ref": "#/$defs/externalRefs" },
    "extensions": { "$ref": "#/$defs/extensions" },
    "createdAt": { "$ref": "#/$defs/dateTime" },
    "updatedAt": { "$ref": "#/$defs/dateTime" },
    "archivedAt": { "$ref": "#/$defs/dateTime" },
    "sourceApp": { "$ref": "#/$defs/sourceApp" }
  },
  "$defs": {
    "dateTime": { "type": "string", "format": "date-time" },
    "discipline": {
      "type": "string",
      "enum": ["figure", "hockey", "speed", "synchro", "recreational", "offIce", "other"]
    },
    "visibility": {
      "type": "string",
      "enum": ["private", "shared", "coachOnly", "team"]
    },
    "sourceApp": {
      "type": "string",
      "enum": ["skatingxCore", "blazeTraining", "blazeJournal", "blazeLab", "blazeAnalysis", "skatingxPlatform", "migration"]
    },
    "externalRefs": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": { "type": ["string", "number", "boolean", "null"] }
      }
    },
    "extensions": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": true
      }
    }
  }
}
