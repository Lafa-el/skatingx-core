{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.skatingx.dev/journal-entry.schema.json",
  "title": "SkatingX Journal Entry",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "entryId",
    "athleteId",
    "ownerUid",
    "schemaVersion",
    "entryDate",
    "entryType",
    "visibility",
    "createdAt",
    "updatedAt",
    "sourceApp"
  ],
  "properties": {
    "entryId": { "type": "string", "minLength": 1 },
    "athleteId": { "type": "string", "minLength": 1 },
    "ownerUid": { "type": "string", "minLength": 1 },
    "schemaVersion": { "type": "string", "pattern": "^1\\.0\\.0$" },
    "entryDate": { "$ref": "#/$defs/dateTime" },
    "timezone": { "type": "string", "maxLength": 80 },
    "entryType": {
      "type": "string",
      "enum": ["reflection", "trainingNote", "competitionReflection", "goal", "coachNote", "parentNote", "wellness", "other"]
    },
    "title": { "type": "string", "maxLength": 160 },
    "prompt": { "type": "string", "maxLength": 500 },
    "body": { "type": "string", "maxLength": 12000 },
    "mood": { "type": "string", "maxLength": 80 },
    "confidence": { "type": "integer", "minimum": 1, "maximum": 10 },
    "energy": { "type": "integer", "minimum": 1, "maximum": 10 },
    "tags": {
      "type": "array",
      "items": { "type": "string", "maxLength": 60 },
      "uniqueItems": true,
      "maxItems": 30
    },
    "relatedTrainingRecordId": { "type": "string" },
    "relatedCompetitionId": { "type": "string" },
    "visibility": { "$ref": "#/$defs/visibility" },
    "status": { "enum": ["draft", "published", "archived"] },
    "externalRefs": { "$ref": "#/$defs/externalRefs" },
    "extensions": { "$ref": "#/$defs/extensions" },
    "createdAt": { "$ref": "#/$defs/dateTime" },
    "updatedAt": { "$ref": "#/$defs/dateTime" },
    "createdByUid": { "type": "string" },
    "updatedByUid": { "type": "string" },
    "archivedAt": { "$ref": "#/$defs/dateTime" },
    "sourceApp": { "$ref": "#/$defs/sourceApp" }
  },
  "$defs": {
    "dateTime": { "type": "string", "format": "date-time" },
    "visibility": { "type": "string", "enum": ["private", "shared", "coachOnly", "team"] },
    "sourceApp": {
      "type": "string",
      "enum": ["skatingxCore", "blazeTraining", "blazeJournal", "blazeLab", "blazeAnalysis", "skatingxPlatform", "migration"]
    },
    "externalRefs": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": { "type": ["string", "number", "boolean", "null"] }
      }
    },
    "extensions": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": true
      }
    }
  }
}
